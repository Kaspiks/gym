node_modules/
yarn.lock

# Ignore master key for decrypting credentials and more.
/config/master.key

/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore Yarn plug'n'play files and install state
.pnp.cjs
.pnp.loader.mjs
.yarn/
# Ignore logs
/log/*
!/log/.keep

# Ignore dev temp files
/tmp/*
!/tmp/.keep
